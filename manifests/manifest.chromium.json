{
  "manifest_version": 3,
  "name": "PubMed to BibTeX",
  "version": "0.0.0",
  "icons": {},
  "permissions": [
    "sidePanel",
    "activeTab",
    "clipboardWrite",
    "storage"
  ],
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://pubmed.ncbi.nlm.nih.gov/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}